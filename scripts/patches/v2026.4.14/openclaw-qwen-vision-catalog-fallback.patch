+
+function listConfiguredModelCatalogEntries(cfg: OpenClawConfig): ModelCatalogEntry[] {
+  const providers = cfg.models?.providers;
+  if (!providers) {
+    return [];
+  }
+  const entries: ModelCatalogEntry[] = [];
+  for (const [providerId, providerConfig] of Object.entries(providers)) {
+    const provider = normalizeOptionalString(providerId) ?? "";
+    if (!provider || !Array.isArray(providerConfig?.models)) {
+      continue;
+    }
+    for (const model of providerConfig.models) {
+      const id = normalizeOptionalString(model?.id) ?? "";
+      if (!id) {
+        continue;
+      }
+      const name = normalizeOptionalString(model?.name ?? id) || id;
+      const contextWindow =
+        typeof model?.contextWindow === "number" && model.contextWindow > 0
+          ? model.contextWindow
+          : undefined;
+      const reasoning = typeof model?.reasoning === "boolean" ? model.reasoning : undefined;
+      const input = Array.isArray(model?.input) ? model.input : undefined;
+      entries.push({ id, name, provider, contextWindow, reasoning, input });
+    }
+  }
+  return entries;
+}
